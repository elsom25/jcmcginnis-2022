---
layout: page
skip_footer: true
page_id: index
head_scripts:
  - gsap
---
    <!-- Hero Section - BOLD with Light/Dark support -->
    <section class="relative hero-extend min-h-[90vh] flex items-center overflow-hidden">
      <!-- Light mode: warm cream with brand accent -->
      <div class="absolute inset-0 bg-gradient-to-br from-stone-50 via-white to-brand-50/30 dark:from-stone-950 dark:via-stone-950 dark:to-stone-900"></div>
      <!-- Dramatic gradient sweep - both modes -->
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_120%_80%_at_20%_-20%,rgba(225,29,72,0.12),transparent_50%)] dark:bg-[radial-gradient(ellipse_120%_80%_at_20%_-20%,rgba(225,29,72,0.35),transparent_50%)]"></div>
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_60%_at_80%_120%,rgba(245,158,11,0.08),transparent_50%)] dark:bg-[radial-gradient(ellipse_80%_60%_at_80%_120%,rgba(245,158,11,0.20),transparent_50%)]"></div>
      <div class="pointer-events-none absolute inset-0 hero-atmosphere"></div>
      <div class="pointer-events-none absolute inset-0 bg-grain"></div>

      <div class="relative w-full max-w-[90rem] mx-auto px-6 md:px-12 hero-content-padding pb-20 md:pb-28">
        <div class="grid lg:grid-cols-12 gap-12 lg:gap-8 items-center">
          <!-- Left: Main content -->
          <div class="lg:col-span-8">
            <!-- Stark credential line -->
            <div class="flex items-center gap-3 sm:gap-6 mb-8 animate-fade-in">
              <div class="h-px w-8 sm:w-12 bg-brand-500 shrink-0"></div>
              <span class="text-[10px] sm:text-xs font-mono uppercase tracking-[0.15em] sm:tracking-[0.3em] text-stone-500 whitespace-nowrap">Engineer · Leader · Author</span>
            </div>

            <!-- MASSIVE H1 -->
            <h1 class="animate-fade-in-up">
              <span class="block text-hero text-6xl sm:text-7xl md:text-8xl lg:text-9xl xl:text-[11rem] text-stone-900 dark:text-white leading-[0.85] tracking-tight">
                I build
              </span>
              <span class="block text-hero text-6xl sm:text-7xl md:text-8xl lg:text-9xl xl:text-[11rem] leading-[0.85] tracking-tight">
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-600 via-brand-500 to-accent-500 dark:from-brand-400 dark:via-brand-500 dark:to-accent-400">teams</span>
              </span>
              <span class="block text-hero text-6xl sm:text-7xl md:text-8xl lg:text-9xl xl:text-[11rem] text-stone-900 dark:text-white leading-[0.85] tracking-tight">
                that ship.
              </span>
            </h1>

            <!-- Single punchy intro -->
            <p class="mt-12 text-xl md:text-2xl text-stone-600 dark:text-stone-400 max-w-2xl leading-relaxed animate-fade-in animate-delay-1">
              <strong class="text-stone-900 dark:text-white">Engineer first, leader always.</strong> Global-scale systems, small teams, ugly tradeoffs. I build teams that ship anyway. Trust is the multiplier.
            </p>

            <!-- CTAs -->
            <div class="mt-10 flex flex-wrap items-center gap-4 animate-fade-in animate-delay-2">
              <a href="/blog/" class="group inline-flex items-center gap-3 px-8 py-4 bg-stone-900 dark:bg-white hover:bg-brand-600 dark:hover:bg-brand-500 text-white dark:text-stone-900 dark:hover:text-white font-bold rounded-full transition-all hover:scale-105">
                Read my writing
                <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
              <a href="/readme/" class="inline-flex items-center gap-2 px-8 py-4 border-2 border-stone-300 dark:border-stone-700 hover:border-brand-500 dark:hover:border-brand-500 text-stone-900 dark:text-white font-semibold rounded-full transition-all hover:bg-brand-500/10">
                <span class="font-mono">README.md</span>
              </a>
            </div>
          </div>

          <!-- Right: Status card -->
          <div class="lg:col-span-4 hidden lg:block animate-fade-in animate-delay-2">
            <div class="relative">
              <!-- Glow -->
              <div class="absolute -inset-4 bg-gradient-to-br from-brand-500/10 to-accent-500/5 dark:from-brand-500/20 dark:to-accent-500/10 rounded-3xl blur-2xl"></div>
              <!-- Card -->
              <div class="relative bg-white/80 dark:bg-stone-900/80 backdrop-blur-sm border border-stone-200 dark:border-stone-800 rounded-2xl p-8 shadow-xl shadow-stone-200/50 dark:shadow-none">
                <div class="flex items-center gap-2 mb-6">
                  <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
                  <span class="text-xs font-mono uppercase tracking-wider text-stone-500">Currently</span>
                </div>
                <% live_era = site.data.career.eras.find { |e| e["current"] } %>
                <% shopify_eras = site.data.career.eras.select { |e| e["company"].to_s == "Shopify" } %>
                <% shopify_era = shopify_eras.last %>
                <% if live_era %>
                  <p class="text-2xl font-bold text-stone-900 dark:text-white mb-2"><%= live_era.role %></p>
                  <p class="text-lg text-brand-600 dark:text-brand-400 mb-6">@ <a href="<%= live_era.url %>" target="_blank" rel="noopener" class="hover:opacity-80 transition-opacity"><%= live_era.company %></a></p>
                <% end %>
                <div class="pt-6 border-t border-stone-200 dark:border-stone-800">
                  <p class="text-sm text-stone-500">
                    Previously @
                    <% if shopify_era %>
                      <a href="<%= shopify_era.url %>" target="_blank" rel="noopener" class="hover:opacity-80 transition-opacity">Shopify</a>
                    <% else %>
                      Shopify
                    <% end %>
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

    </section>

    <!-- MY JOURNEY — narrative instrument panel: copy-first, shared rail axis -->
    <section id="lessons" class="lessons-stage relative border-t border-stone-200/80 dark:border-stone-800/60">
      <div class="absolute inset-0 bg-linear-to-b from-stone-50 via-white to-stone-100/70 dark:from-stone-950 dark:via-[#111113] dark:to-black"></div>
      <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_95%_56%_at_20%_-20%,rgba(225,29,72,0.06),transparent_60%)] dark:bg-[radial-gradient(ellipse_100%_58%_at_20%_-20%,rgba(244,63,94,0.12),transparent_60%)]"></div>
      <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_90%_62%_at_78%_118%,rgba(245,158,11,0.05),transparent_58%)] dark:bg-[radial-gradient(ellipse_90%_62%_at_78%_118%,rgba(245,158,11,0.10),transparent_58%)]"></div>
      <div class="pointer-events-none absolute inset-0 lessons-atmosphere"></div>
      <div class="pointer-events-none absolute inset-0 bg-grain"></div>
      <div class="pointer-events-none absolute inset-x-0 bottom-0 h-24 bg-linear-to-b from-transparent to-stone-950/8 dark:to-black/18"></div>

      <div class="relative z-10 w-full max-w-[90rem] mx-auto px-6 md:px-12">
        <div class="relative">
          <div class="pt-16 pb-8 md:pt-24 md:pb-12">
            <%= render "section_header", label: "My Journey", color: "stone", alignment: "left", size: "small" %>
            <h2 class="text-hero mt-4 text-3xl leading-[1.05] text-stone-900 sm:text-4xl md:text-5xl lg:text-[3.2rem] dark:text-white">
              <span class="text-stone-900 dark:text-white">Chaos isn't the enemy.</span><br>
              <span class="text-stone-500 dark:text-brand-400/95">Comfort is.</span>
            </h2>
          </div>

          <div id="timeline-container" class="relative z-[1] pb-20 md:pb-28 lg:pb-0">
            <!-- Rail: fixed x-axis via CSS — dots + index share w-11 column -->
            <div id="timeline-track" class="hidden md:block absolute top-0 left-[var(--lessons-rail-center)] z-[1] w-px -translate-x-1/2 pointer-events-none" style="height: 0;">
              <div class="absolute inset-0 bg-stone-300/85 dark:bg-stone-700/55"></div>
              <div id="timeline-fill" class="absolute top-0 left-0 right-0 overflow-hidden" style="height: 0%;">
                <div class="absolute top-0 left-0 right-0 h-[8000px] w-px bg-brand-500/70 dark:bg-brand-500/55"></div>
              </div>
            </div>

            <% chapter_offset = 0 %>
            <% site.data.career.eras.each_with_index do |era, era_idx| %>
              <% visible_chapter_count =
                   Array(era["chapters"]).then do |chapters|
                     if chapters.empty?
                       Array(era["markers"]).map(&:to_s).map(&:strip).reject(&:empty?).any? ? 1 : 0
                     else
                       chapters.count do |chapter_data|
                         Array(chapter_data["markers"]).map(&:to_s).map(&:strip).reject(&:empty?).any?
                       end
                     end
                   end %>
              <%= render "career_era", era: era, index: era_idx, is_last: era_idx == site.data.career.eras.size - 1, chapter_offset: chapter_offset %>
              <% chapter_offset += visible_chapter_count %>
            <% end %>
            <div class="hidden h-28 lg:block" aria-hidden="true"></div>
          </div>

        </div>
      </div>
    </section>

    <section id="thesis-section" class="relative border-t border-stone-200 dark:border-stone-800 bg-stone-950 text-stone-100 dark:bg-black">
      <div class="pointer-events-none absolute inset-x-0 top-0 h-20 bg-linear-to-b from-white/2 to-transparent dark:from-white/[0.03]"></div>
      <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_80%_60%_at_20%_10%,rgba(244,63,94,0.10),transparent_55%)] dark:bg-[radial-gradient(ellipse_80%_60%_at_20%_10%,rgba(244,63,94,0.14),transparent_55%)]"></div>
      <div class="w-full max-w-[90rem] mx-auto px-6 py-28 md:px-12 md:py-36">
        <div class="mx-auto max-w-[42rem]">
          <p class="mb-12 font-mono text-[10px] uppercase tracking-[0.34em] text-stone-500 dark:text-stone-500">
            The Thesis
          </p>

          <blockquote class="space-y-7 md:space-y-8">
            <p class="max-w-[15ch] font-serif text-4xl leading-[0.96] tracking-tight text-stone-100 sm:text-5xl md:text-[3.65rem]">
              High-agency trumps everything.
            </p>
            <p class="max-w-[17ch] font-serif text-4xl leading-[0.96] tracking-tight text-stone-100 sm:text-5xl md:text-[3.65rem]">
              Trust is the multiplier.
            </p>
            <p class="max-w-[18ch] font-serif text-4xl leading-[0.96] tracking-tight text-stone-100 sm:text-5xl md:text-[3.65rem]">
              Directed chaos forges it.
            </p>
          </blockquote>
        </div>
      </div>
    </section>

    <!-- Explore More -->
    <section class="py-24 md:py-32 bg-stone-50 dark:bg-stone-900/50">
      <div class="w-full max-w-[90rem] mx-auto px-6 md:px-12">
        <div class="reveal-on-scroll">
          <%= render "section_header", label: "Explore More", color: "brand" %>
        </div>

        <div class="grid lg:grid-cols-12 gap-6 md:gap-8">
          <% if featured_post %>
            <article class="reveal-on-scroll [--stagger:0] lg:col-span-7">
              <%= render "card", color: "brand", size: "xl", rounded: "3xl", shadow_size: "2xl", href: featured_post.relative_url do %>
                <div class="flex items-center gap-4 mb-6">
                  <span class="px-3 py-1 text-xs font-bold uppercase tracking-wider bg-brand-100 dark:bg-brand-900/50 text-brand-700 dark:text-brand-300 rounded-full">Featured Essay</span>
                  <span class="text-sm text-stone-400 dark:text-stone-600"><%= featured_post.date.strftime("%B %Y") %></span>
                </div>
                <h3 class="font-serif text-3xl md:text-4xl font-semibold text-stone-900 dark:text-stone-100 mb-4 group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors">
                  <%= featured_post.data.title %>
                </h3>
                <% if featured_post.data.pull_quote %>
                  <blockquote class="pl-6 border-l-4 border-brand-500 mb-6">
                    <p class="font-serif text-xl text-stone-700 dark:text-stone-300 italic leading-relaxed">
                      "<%= featured_post.data.pull_quote %>"
                    </p>
                  </blockquote>
                <% end %>
                <% if featured_post.data.description %>
                  <p class="text-lg text-stone-600 dark:text-stone-400 leading-relaxed mb-8">
                    <%= featured_post.data.description %>
                  </p>
                <% end %>
                <div class="inline-flex items-center gap-2 text-brand-600 dark:text-brand-400 font-semibold group-hover:gap-4 transition-all">
                  Read the full essay
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </div>
              <% end %>
            </article>
          <% end %>

          <div class="lg:col-span-5 flex flex-col gap-6 md:gap-8">
            <% second_post = featured_posts.find { it != featured_post } %>
            <% if second_post %>
              <article class="reveal-on-scroll [--stagger:1] flex-1">
                <%= render "card", color: "brand", size: "md", shadow_size: "xl", h_full: true, href: second_post.relative_url do %>
                  <div class="flex items-center gap-3 mb-4">
                    <span class="text-sm text-stone-400 dark:text-stone-600"><%= second_post.date.strftime("%B %Y") %></span>
                    <% second_post.data.categories&.each do |category| %>
                      <span class="text-sm font-medium text-brand-600 dark:text-brand-400"><%= category %></span>
                    <% end %>
                  </div>
                  <h4 class="font-serif text-xl md:text-2xl font-semibold text-stone-900 dark:text-stone-100 mb-3 group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors">
                    <%= second_post.data.title %>
                  </h4>
                  <% if second_post.data.description %>
                    <p class="text-stone-600 dark:text-stone-400 leading-relaxed">
                      <%= second_post.data.description %>
                    </p>
                  <% end %>
                <% end %>
              </article>
            <% end %>

            <div class="reveal-on-scroll [--stagger:2] grid grid-cols-2 gap-4">
              <%= render "card", color: "brand", size: "sm", rounded: "xl", href: "/blog/" do %>
                <div class="w-10 h-10 flex items-center justify-center rounded-lg bg-brand-100 dark:bg-brand-900/30 text-brand-600 dark:text-brand-400 mb-3 group-hover:scale-110 transition-transform">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
                  </svg>
                </div>
                <p class="font-semibold text-stone-900 dark:text-stone-100 mb-1">All Writing</p>
                <p class="text-sm text-stone-500">Essays & thoughts</p>
              <% end %>

              <%= render "card", color: "accent", size: "sm", rounded: "xl", href: "/talks/" do %>
                <div class="w-10 h-10 flex items-center justify-center rounded-lg bg-accent-100 dark:bg-accent-900/30 text-accent-600 dark:text-accent-400 mb-3 group-hover:scale-110 transition-transform">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5M9 11.25v1.5M12 9v3.75m3-6v6" />
                  </svg>
                </div>
                <p class="font-semibold text-stone-900 dark:text-stone-100 mb-1">Speaking</p>
                <p class="text-sm text-stone-500">Talks & workshops</p>
              <% end %>
            </div>
          </div>

          <div class="reveal-on-scroll [--stagger:3] lg:col-span-12">
          <%= render "card", color: "brand", size: "lg", bold: true, shadow_size: "2xl", rounded: "2xl", href: site.data.career.book.url, external: true do %>
            <div class="absolute inset-0 bg-gradient-to-r from-brand-600/10 via-transparent to-accent-600/10 opacity-0 group-hover:opacity-100 transition-opacity rounded-2xl pointer-events-none"></div>
            <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
              <div class="flex items-center gap-6">
                <div class="w-16 h-16 flex items-center justify-center rounded-2xl bg-white/10 text-white group-hover:scale-110 transition-transform">
                  <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
                  </svg>
                </div>
                <div>
                  <h3 class="font-serif text-2xl md:text-3xl font-semibold text-white mb-1">
                    The Book
                    <svg class="inline w-5 h-5 ml-2 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                    </svg>
                  </h3>
                  <p class="text-stone-300">
                    <em class="text-brand-400"><%= site.data.career.book.title %></em> — <%= site.data.career.book.tagline.downcase %>
                  </p>
                </div>
              </div>
              <div class="flex items-center gap-2 text-white font-semibold group-hover:gap-4 transition-all">
                <span>Get the book</span>
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </div>
            </div>
          <% end %>
          </div>
        </div>
      </div>
    </section>

    <!-- Connect Section - Bold Accent Zone -->
    <section class="relative py-32 md:py-48 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-brand-600 via-brand-700 to-stone-900">
        <div class="absolute inset-0 pattern-plus opacity-30"></div>
      </div>

      <div class="absolute top-1/2 left-1/4 -translate-y-1/2 w-64 h-64 bg-white/5 rounded-full blur-3xl"></div>
      <div class="absolute top-1/2 right-1/4 -translate-y-1/2 w-96 h-96 bg-accent-500/10 rounded-full blur-3xl"></div>

      <!-- Geometric decorations -->
      <div class="absolute top-16 left-[8%] w-20 h-20 border-2 border-white/10 rotate-12 hidden lg:block"></div>
      <div class="absolute bottom-16 right-[8%] w-28 h-28 border-2 border-white/10 -rotate-6 hidden lg:block"></div>

      <div class="relative z-10 w-full max-w-[72rem] mx-auto px-6 md:px-12 text-center">
        <div class="reveal-on-scroll">
          <h2 class="text-hero text-4xl md:text-5xl lg:text-6xl text-white mb-6">
            Let's build something<br class="hidden sm:block" /> <em class="text-accent-300">extraordinary</em>
          </h2>
          <p class="text-xl text-white/70 max-w-2xl mx-auto mb-12">
            Leadership, teams, and the messy middle between strategy and code. If you're wrestling with that, say hello.
          </p>
        </div>

        <a href="mailto:jesse@jcmcginnis.com" class="reveal-on-scroll [--stagger:1] group inline-flex items-center gap-3 px-10 py-5 bg-white hover:bg-stone-100 text-stone-900 text-lg font-bold rounded-full transition-all hover:scale-105 shadow-2xl mb-10">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          jesse@jcmcginnis.com
        </a>

        <div class="reveal-on-scroll [--stagger:2] pt-4">
          <%= render "social_links", style: "pills", color: "white", show_labels: true %>
        </div>
      </div>
    </section>
